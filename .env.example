LLM_BACKEND=mock
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
REQUEST_TIMEOUT_SECONDS=120

DATA_DIR=data
INDEX_DIR=data/.index
CHUNK_SIZE=400
CHUNK_OVERLAP=60
TOP_K=4

# Cross-encoder reranker on top of BM25+TFIDF/pgvector (retrieval/reranker.py).
# Falls back to no reranking automatically if sentence-transformers isn't
# installed -- see docs/bugs-found.md #3 for why that fallback matters.
USE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_CANDIDATE_POOL=20

# self_correcting_rag_agent.py: how many retrieve->generate->verify loops
# before giving up and returning the best answer flagged as unverified.
SELF_CORRECTION_MAX_RETRIES=2

# --- Vector storage: "memory" (pickle file, zero setup) or "postgres"
# (pgvector, durable, shared across processes -- see docker-compose.yml) ---
VECTOR_BACKEND=memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chat session history: "memory" (in-process dict, resets on restart) or
# "postgres" (durable, Redis-cached reads when REDIS_URL is reachable) ---
CHAT_HISTORY_BACKEND=memory
SESSION_CACHE_TTL_SECONDS=3600

# Shared by both VECTOR_BACKEND=postgres and CHAT_HISTORY_BACKEND=postgres.
# Matches the credentials docker-compose.yml's `postgres` service creates.
POSTGRES_DSN=postgresql+psycopg2://agentlab:agentlab@localhost:5432/agentlab
REDIS_URL=redis://localhost:6379/0
